<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net48;net9.0</TargetFrameworks>
    <AssemblyName>namasdev.Net.en</AssemblyName>
    <RootNamespace>namasdev.Net.en</RootNamespace>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <Deterministic>true</Deterministic>
    <PackageId>namasdev.Net.en</PackageId>
    <Version>2.0.0</Version>
    <Authors>Matias Alberto Lopez</Authors>
    <Description>namasdev Net library (English)</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Copyright>2024</Copyright>
    <PackageTags>namasdev</PackageTags>
    <AssemblyVersion>2.0.0</AssemblyVersion>
    <FileVersion>2.0.0</FileVersion>
  </PropertyGroup>

  <ItemGroup>
    <!-- System.Net.Mail and System.Net.FtpWebRequest are available in net9.0 BCL. -->
    <PackageReference Include="namasdev.Core.en" Version="2.0.0" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net48'">
    <Reference Include="System.Transactions" />
    <Reference Include="System.Data.DataSetExtensions" />
    <Reference Include="Microsoft.CSharp" />
  </ItemGroup>

</Project>
